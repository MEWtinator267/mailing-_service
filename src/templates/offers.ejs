<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Exclusive Offers Just for You</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, sans-serif; background-color: #f4f7f9; color: #1a1a2e; }
    .wrapper { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    .header { background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%); padding: 48px 40px; text-align: center; }
    .header img { height: 40px; margin-bottom: 20px; }
    .header h1 { color: #ffffff; font-size: 28px; font-weight: 700; letter-spacing: -0.5px; }
    .header p { color: rgba(255,255,255,0.9); font-size: 16px; margin-top: 8px; }
    .body { padding: 40px; }
    .greeting { font-size: 20px; font-weight: 600; margin-bottom: 12px; color: #1a1a2e; }
    .text { font-size: 15px; line-height: 1.7; color: #4b5563; margin-bottom: 28px; }
    .offers-grid { margin: 0 0 32px; }
    .offer-card { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 24px; margin-bottom: 16px; position: relative; overflow: hidden; }
    .offer-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: linear-gradient(135deg, #f59e0b, #ef4444); }
    .offer-badge { display: inline-block; background: #fef3c7; color: #d97706; font-size: 12px; font-weight: 700; padding: 3px 10px; border-radius: 99px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
    .offer-badge.free { background: #dcfce7; color: #16a34a; }
    .offer-title { font-size: 17px; font-weight: 700; color: #1a1a2e; margin-bottom: 8px; }
    .offer-desc { font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 14px; }
    .offer-meta { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .offer-expiry { font-size: 12px; color: #9ca3af; }
    .offer-expiry span { color: #ef4444; font-weight: 600; }
    .offer-cta { display: inline-block; background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%); color: #ffffff; text-decoration: none; padding: 9px 20px; border-radius: 7px; font-size: 13px; font-weight: 600; }
    .divider { border: none; border-top: 1px solid #e5e7eb; margin: 32px 0; }
    .no-offers { text-align: center; padding: 32px; background: #f8fafc; border-radius: 10px; color: #6b7280; font-size: 15px; }
    .footer { padding: 24px 40px; background: #f8fafc; text-align: center; }
    .social-links { margin-bottom: 12px; }
    .social-links a { display: inline-block; margin: 0 8px; color: #f59e0b; text-decoration: none; font-size: 13px; font-weight: 500; }
    .footer-text { font-size: 12px; color: #9ca3af; line-height: 1.6; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <% if (logoUrl) { %>
        <img src="<%= logoUrl %>" alt="<%= appName %> logo" />
      <% } %>
      <h1>Exclusive Offers Just for You 🎁</h1>
      <p>Hand-picked deals waiting for you, <%= name %>!</p>
    </div>

    <div class="body">
      <p class="greeting">Hey <%= name %>,</p>

      <p class="text">
        Welcome back! We noticed you just logged in, so we put together some exclusive offers
        just for you. These deals are available for a limited time — don't miss out!
      </p>

      <div class="offers-grid">
        <% if (offers && offers.length > 0) { %>
          <% offers.forEach(function(offer) { %>
            <div class="offer-card">
              <% if (parseFloat(offer.discount_percentage) > 0) { %>
                <span class="offer-badge"><%= parseFloat(offer.discount_percentage) %>% OFF</span>
              <% } else { %>
                <span class="offer-badge free">Special Deal</span>
              <% } %>
              <div class="offer-title"><%= offer.title %></div>
              <div class="offer-desc"><%= offer.description %></div>
              <div class="offer-meta">
                <div class="offer-expiry">
                  Expires: <span><%= new Date(offer.expiry_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                </div>
                <% if (offer.cta_url) { %>
                  <a href="<%= offer.cta_url %>" class="offer-cta">View Offer →</a>
                <% } %>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="no-offers">
            <p>No active offers right now — check back soon for great deals!</p>
          </div>
        <% } %>
      </div>

      <p class="text">
        Questions about any of these offers? We're here to help — just reply to this email.
      </p>

      <p class="text">
        Happy shopping,<br />
        <strong>The <%= appName %> Team</strong>
      </p>
    </div>

    <hr class="divider" style="margin: 0;" />

    <div class="footer">
      <div class="social-links">
        <a href="#">Twitter</a>
        <a href="#">LinkedIn</a>
        <a href="#">Instagram</a>
      </div>
      <p class="footer-text">
        You received this email because you recently logged into <%= appName %>.<br />
        © <%= new Date().getFullYear() %> <%= appName %>. All rights reserved.
      </p>
    </div>
  </div>
</body>
</html>
