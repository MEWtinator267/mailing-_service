PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mailing_service
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@company.com
SMTP_PASS=your_smtp_password

FROM_EMAIL=noreply@company.com
FROM_NAME=Company Name

# App
APP_NAME=MyApp
APP_DASHBOARD_URL=https://app.company.com/dashboard
APP_LOGO_URL=https://app.company.com/logo.png

# Offers data source: database | config_file
OFFERS_DATA_SOURCE=database

LOG_LEVEL=info

NODE_ENV=development
